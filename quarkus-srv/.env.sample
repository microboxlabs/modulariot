# =============================================================================
# ModularIoT — Environment Variables
# =============================================================================
# Copy to .env and fill in your values:  cp .env.sample .env
# Quarkus loads .env automatically via MicroProfile Config.

# --- Primary database ---
MIOT_DB_USER=miot
MIOT_DB_PASSWORD=change_me
MIOT_DB_REACTIVE_URL=postgresql://localhost:5432/miot_dev
MIOT_DB_JDBC_URL=jdbc:postgresql://localhost:5432/miot_dev

# --- Metrics database (read-only GPS/OBD2) ---
METRICS_DB_USER=change_me
METRICS_DB_PASSWORD=change_me
METRICS_DB_URL=postgresql://localhost:8432/your_metrics_db

# --- Auth0 ---
AUTH0_ISSUER=https://your-tenant.auth0.com/
# HS256 signing secret (Auth0 > APIs > your API > Settings > Signing Secret)
AUTH0_HS256_SECRET=change_me
# RS256 JWKS endpoint (Auth0 OIDC discovery)
AUTH0_JWKS_URL=https://your-tenant.auth0.com/.well-known/jwks.json

# --- Alfresco ---
ALFRESCO_URL=http://localhost:8080/alfresco
ALFRESCO_USER=change_me
ALFRESCO_PASSWORD=change_me

# --- External messaging ---
# log = standalone (no broker needed), pulsar = Apache Pulsar
MIOT_MESSAGING_TYPE=log
PULSAR_URL=pulsar://localhost:6650
MIOT_TRACKING_TOPIC=persistent://your-tenant/tracking/asset-positions
