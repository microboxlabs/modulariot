# =============================================================================
# miot-harness configuration template
# -----------------------------------------------------------------------------
# Copy to `.env` and fill in real values. `.env` is gitignored.
# Every setting declared in `src/miot_harness/config.py` has an entry here so
# new operators can audit the full surface in one file.
#
# Conventions:
# - MIOT_HARNESS_* envs are harness-owned (per pydantic-settings env_prefix).
# - Provider keys (ANTHROPIC_API_KEY, OPENAI_API_KEY, GOOGLE_API_KEY) are
#   unprefixed and read via standard provider names.
# - All values shown below are *defaults* or *placeholders* — never real
#   secrets, never real URLs.
# =============================================================================

# -----------------------------------------------------------------------------
# Model provider keys (Deep Agents accepts any LangChain-supported chat model)
# -----------------------------------------------------------------------------
# Required when any agent is configured to a `claude-*` or `gpt-*` model.
# Leave commented in this template; provide in your local `.env` only.
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# GOOGLE_API_KEY=

# -----------------------------------------------------------------------------
# Harness identity
# -----------------------------------------------------------------------------
# Surfaces in `/health.env`. Use `local` / `dev` / `staging` / `prod`.
MIOT_HARNESS_ENV=local

# Where the file-based run_store + workspace artifacts live.
MIOT_HARNESS_WORKSPACE_DIR=.miot-workspace

# Default tenant/user when a request omits them. Per project policy, real
# tenant context comes from authenticated server context, not from these.
MIOT_HARNESS_DEFAULT_TENANT_ID=demo-tenant
MIOT_HARNESS_DEFAULT_USER_ID=demo-user

# -----------------------------------------------------------------------------
# Datasource connection / domain overrides (provider-agnostic)
# -----------------------------------------------------------------------------
# Selects the DataSourceProvider from datasource/registry.py.
MIOT_HARNESS_DATASOURCE_KIND=nexo

# Standard Postgres connection string (DSN) for the Coordinador database:
#   postgresql://user:password@host:port/database
# This is the sole source of Nexo DB credentials. The harness expects a
# read-only `harness` PG role to exist in the target DB. Leave commented
# to disable the Nexo integration — the harness still serves non-Nexo
# runs with mocked tools.
# MIOT_HARNESS_DATASOURCE_DSN=postgresql://user:password@host:6432/citus

# Surfaces in Postgres `pg_stat_activity.application_name` so DBAs can
# attribute connections to the harness without log correlation.
MIOT_HARNESS_DATASOURCE_APPLICATION_NAME=miot-harness

# Hard tenant lock applied to every coordinador_* tool call. Must match
# MIOT_HARNESS_DEFAULT_TENANT_ID for end-to-end runs. Leave unset to use
# the provider profile's default lock.
MIOT_HARNESS_DATASOURCE_TENANT_LOCK=mintral

# Postgres schema where `fn_dx_*` functions live. Validated against
# `^[a-z_][a-z0-9_]*$` at boot — invalid names disable Nexo fail-closed.
# Provider-private (Nexo-specific Postgres concept), so it keeps the
# MIOT_HARNESS_NEXO_* prefix.
MIOT_HARNESS_NEXO_SEARCH_PATH=nexo

# EXPLAIN plan-cost refuse gate for the composable Nexo primitives.
# Provider-private (PostgreSQL plan-cost units). Default 10000.
# MIOT_HARNESS_NEXO_EXPLAIN_COST_THRESHOLD=10000

# Snapshot freshness gates in minutes. Boot probes `fn_dx_centro_control`
# and disables Nexo if the data is older than the *refuse* threshold.
# `warn` is informational; `refuse` is a hard gate. Leave unset to use
# the provider profile's defaults.
MIOT_HARNESS_DATASOURCE_FRESHNESS_WARN_MINUTES=30
MIOT_HARNESS_DATASOURCE_FRESHNESS_REFUSE_MINUTES=240

# -----------------------------------------------------------------------------
# Agent / graph settings
# -----------------------------------------------------------------------------
# Max LangGraph turns per run. Cap exists so a misbehaving plan can't
# loop indefinitely; surfaces as a planning failure if reached.
MIOT_HARNESS_AGENTS_MAX_TURNS=8

# Wires the critic node into the conversational graph. Off by default
# because it doubles model spend per run.
MIOT_HARNESS_AGENTS_CRITIC_ENABLED=false

# Multi-agent model assignment (per plan §"Cost-control rules").
# `rule` = deterministic keyword routing (cheap, recommended for prod).
# `llm` = supervisor delegates to a small model for routing decisions.
MIOT_HARNESS_AGENTS_SUPERVISOR_MODE=rule

# Per-agent model. Haiku for high-throughput cheap tiers, Sonnet for
# reasoning. See `agents/chat_models.py` for the prefix → provider map
# (claude-* → Anthropic, gpt-*/o1-*/o3-* → OpenAI).
MIOT_HARNESS_AGENTS_FILTER_EXPERT_MODEL=claude-haiku-4-5
MIOT_HARNESS_AGENTS_ANALYST_MODEL=claude-sonnet-4-6
MIOT_HARNESS_AGENTS_SYNTHESIZER_MODEL=claude-sonnet-4-6
MIOT_HARNESS_AGENTS_CRITIC_MODEL=claude-sonnet-4-6
MIOT_HARNESS_AGENTS_SUMMARIZER_MODEL=claude-haiku-4-5

# -----------------------------------------------------------------------------
# Phase E: LLM intent router + composable primitives (plan 13)
# -----------------------------------------------------------------------------
# Model used by `LLMIntentRouter` to classify every "auto" mode request
# into NEXO_QUERY | NEXO_META | NEXO_AGENTIC | STORYTELLING_RUN | DIRECT
# | OTHER. Haiku tier by default — the router is called on every request.
MIOT_HARNESS_INTENT_ROUTER_MODEL=claude-haiku-4-5

# Below this confidence the LLM label is dropped and the deterministic
# keyword router decides instead. Tune up if misclassifications hurt
# quality; tune down if too many edge cases are falling through.
MIOT_HARNESS_INTENT_ROUTER_CONFIDENCE_THRESHOLD=0.7

# Composable primitives EXPLAIN total-cost ceiling (PostgreSQL plan-cost
# units). `nexo_explain` refuses queries above this — keeps unindexed
# cross-joins and seq-scan hell from reaching the DB.
MIOT_HARNESS_NEXO_EXPLAIN_COST_THRESHOLD=10000.0

# Conversation memory hydration token budget. The supervisor trims
# prior turns via `trim_messages(..., token_counter="approximate")` so
# the spliced history stays under this many tokens before being passed
# into LLM-bearing agents' prompts. 24K is ~12% of Haiku-4-5's 200K
# context window; lower = cheaper per turn but loses older context
# faster; higher = better continuity at higher per-call cost.
MIOT_HARNESS_CONVERSATION_TOKEN_BUDGET=24000

# -----------------------------------------------------------------------------
# Operations / observability
# -----------------------------------------------------------------------------
# Standard log level. Container deploys typically set this via the platform's
# config/secret store, not in the image.
MIOT_HARNESS_LOG_LEVEL=INFO

# HTTP header name carrying a request id for tracing propagation across
# the harness ↔ caller boundary. Defaults to the de facto x-request-id.
MIOT_HARNESS_REQUEST_ID_HEADER=x-request-id

# -----------------------------------------------------------------------------
# OpenTelemetry + Langfuse (Phase A telemetry foundation)
# -----------------------------------------------------------------------------
# Off by default — the FastAPI lifespan skips configure_tracing + Traceloop.init
# when this is unset, so local dev pays zero overhead. Flip on once the
# infra/observability/ docker-compose stack is up.
MIOT_HARNESS_OTEL_ENABLED=false

# OTLP gRPC endpoint of the local OTel Collector sidecar. The collector
# fans out to Langfuse (and optionally a second backend) so the harness
# never speaks to Langfuse directly.
MIOT_HARNESS_OTEL_ENDPOINT=http://localhost:4317

# Resource attrs the collector and Langfuse filter / group by.
MIOT_HARNESS_OTEL_SERVICE_NAME=miot-harness
MIOT_HARNESS_OTEL_ENVIRONMENT=local

# Langfuse project keys (created by infra/observability/bootstrap.sh).
# Leave commented in this template; provide in your local .env only.
# MIOT_HARNESS_LANGFUSE_PUBLIC_KEY=pk-lf-...
# MIOT_HARNESS_LANGFUSE_SECRET_KEY=sk-lf-...

# Langfuse host the cost-report CLI fetches traces from. Default is the
# local docker-compose stack; override for a deployed Langfuse.
MIOT_HARNESS_LANGFUSE_HOST=http://localhost:3000

# -----------------------------------------------------------------------------
# Context & Skills subsystem (file-backed; ConfigMap-overridable)
# -----------------------------------------------------------------------------
# Directories of YAML/Markdown context docs and skill manifests. Defaults
# are packaged in the image, so the harness boots with no mounted config.
# Mount a ConfigMap/volume and point these at it to add context and skills
# without rebuilding the image.
# MIOT_HARNESS_CONTEXT_DIR=/etc/miot/context
# MIOT_HARNESS_SKILLS_DIR=/etc/miot/skills
MIOT_HARNESS_CONTEXT_SOURCE_KIND=file
MIOT_HARNESS_SKILLS_SOURCE_KIND=file
# Cap on connector tools registered from skill files (blast-radius bound).
MIOT_HARNESS_MAX_CONNECTOR_TOOLS=50
# When true, a malformed manifest fails /health/ready instead of only
# logging. Keep false in dev; prod sets true (see .env.prod.template).
MIOT_HARNESS_CONTEXT_SKILLS_STRICT=false
# HTTP connector secrets are referenced as ${ENV_VAR} inside manifests and
# resolved from these env vars at call time — never store secrets in the
# mounted files themselves.
# STATUS_PAGE_TOKEN=
