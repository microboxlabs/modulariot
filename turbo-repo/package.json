{
  "name": "modulariot-tuborepo",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "storm": "turbo run storm",
    "lint": "turbo run lint --filter='!@modulariot/web-admin'",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types --filter='!@modulariot/web-admin'",
    "test": "turbo run test",
    "knip": "turbo run knip",
    "knip:check": "turbo run knip:check",
    "prepare": "husky",
    "postinstall": "patch-package",
    "sonarcloud:issues": "node packages/sonarcloud-tools/dist/cli.js issues -k microboxlabs_modulariot",
    "sonarcloud:rule-doc": "node packages/sonarcloud-tools/dist/cli.js rule-doc"
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "patch-package": "^8.0.1",
    "prettier": "^3.5.3",
    "turbo": "^2.5.4",
    "typescript": "5.8.2"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "overrides": {
    "@types/react": "19.2.10",
    "@types/react-dom": "19.2.3",
    "@luma.gl/core": "9.2.6",
    "@luma.gl/engine": "9.2.6",
    "@luma.gl/gltf": "9.2.6",
    "@luma.gl/shadertools": "9.2.6",
    "@luma.gl/webgl": "9.2.6"
  },
  "packageManager": "npm@10.2.4",
  "dependencies": {
    "handlebars": "^4.7.9"
  }
}
