{
  "$schema": "https://v2-9-18.turborepo.dev/schema.json",
  "ui": "stream",
  "globalDependencies": [".env"],
  "globalEnv": [
    "NEXT_PUBLIC_INGEST_URL",
    "NODE_ENV",
    "MIOT_BUILD_INFO_JSON",
    "BUILD_CHANNEL",
    "RELEASE_VERSION",
    "RELEASE_NOTES_VERSION",
    "STACK_TAG",
    "GIT_SHA",
    "SHORT_SHA",
    "BUILT_AT",
    "DEPLOYED_AT",
    "WORKFLOW_RUN_URL",
    "APP_VERSION",
    "APP_TAG",
    "APP_IMAGE_REPOSITORY",
    "APP_IMAGE_TAG",
    "APP_IMAGE_REF",
    "MODULITH_VERSION",
    "MODULITH_TAG",
    "MODULITH_IMAGE_REPOSITORY",
    "MODULITH_IMAGE_TAG",
    "MODULITH_IMAGE_REF",
    "MODULITH_SOURCE_TAG",
    "HARNESS_VERSION",
    "HARNESS_TAG",
    "HARNESS_IMAGE_REPOSITORY",
    "HARNESS_IMAGE_TAG",
    "HARNESS_IMAGE_REF",
    "HARNESS_SOURCE_TAG",
    "LOG_LEVEL",
    "LOG_HANDLERS_CONFIG",
    "APP_TITLE",
    "APP_DESCRIPTION",
    "STREAMHUB_CLIENT_ID",
    "STREAMHUB_CLIENT_SECRET",
    "STREAMHUB_AUDIENCE",
    "STREAMHUB_URL",
    "STREAMHUB_IOT_URL",
    "MIOT_CALENDAR_URL",
    "MIOT_ORGANIZATION_ID",
    "MIOT_OAUTH_AUDIENCE",
    "MIOT_OAUTH_AUTHORIZE_URL",
    "MIOT_OAUTH_CLIENT_ID",
    "MIOT_OAUTH_SCOPE",
    "MIOT_OAUTH_TOKEN_URL",
    "MIOT_LOGIN_URL",
    "MIOT_COLLABORATORS_SOURCE",
    "OPENAPI_URL",
    "OPENAPI_TOKEN",
    "PGREST_BULK_CONCURRENCY",
    "PGREST_BULK_ROW_TIMEOUT_MS",
    "PGREST_PARSE_MAX_BYTES",
    "DASHLET_INGESTION_TIMEZONE",
    "DASHLET_INGESTION_CLIENT_ID",
    "DASHLET_INGESTION_SCHEMA_VERSION",
    "TASK_DRIVEN_ORIGINS",
    "ENABLE_SEARCHBAR"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**"],
      "envMode": "loose",
      "env": []
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "check-types": {
      "dependsOn": ["^build"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "storm": {
      "cache": false,
      "persistent": true
    },
    "test": {
      "cache": false,
      "persistent": true
    },
    "knip": {
      "cache": false
    },
    "knip:check": {
      "cache": false
    },
    "db:generate": {
      "cache": false
    },
    "db:migrate": {
      "cache": false,
      "persistent": true 
    },
    "db:deploy": {
      "cache": false
    }
  }
}
