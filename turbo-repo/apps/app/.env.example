# ─── Authentication ───────────────────────────────────────────────
AUTH_SECRET=your_auth_secret
AUTH_PROVIDER=ECM

# Auth0 (single OIDC broker — required for all OAuth/SAML providers)
# AUTH_AUTH0_ID=your_auth0_client_id
# AUTH_AUTH0_SECRET=your_auth0_client_secret
# AUTH_AUTH0_ISSUER=https://your-tenant.auth0.com

# Auth providers configuration (controls which login buttons are shown)
# All OAuth/SAML providers route through Auth0 — AUTH_AUTH0_* vars must be set.
# SaaS: AUTH_PROVIDERS=google,github,saml* (default, no need to set)
# Custom (Microsoft via Auth0): AUTH_PROVIDERS=microsoft-entra-id*,credentials
# Use * to mark primary providers (highlighted button)
AUTH_PROVIDERS=google,github,saml*

# Restrict who may sign in via OAuth/social (Auth0 → Google/Microsoft/etc.) to these
# email domains. Comma-separated; set per environment/instance. Leave unset/empty to
# allow all domains. Credentials (Alfresco) logins are not affected by this list.
# AUTH_ALLOWED_EMAIL_DOMAINS=microboxlabs.com,vialabs.net

# ─── ECM / Alfresco ─────────────────────────────────────────────
ECM_API_URL=https://your-ecm-host.com
NEXT_PUBLIC_ECM_API_URL=https://your-ecm-host.com
CONTEXT_ROOT=alfresco

# ─── Autentia ────────────────────────────────────────────────────
NEXT_PUBLIC_AUTENTIA_PATH="autentia-path"
NEXT_PUBLIC_SIMULATE_AUTENTIA=false

# ─── CAP (firma electrónica avanzada) ───────────────────────────
CAP_API_URL=https://your-cap-host.com
CAP_USER=your_cap_user
CAP_USER_PIN=your_cap_pin
CAP_API_KEY=your_cap_api_key

# ─── DEC5 ────────────────────────────────────────────────────────
DEC5_INSTITUTION=your_institution
DEC5_SIGNER_ROLES=your_signer_role
DEC5_TARGET_CONTENT_TYPE=your_content_type
DEC5_DISPATCHER_ROLE=your_dispatcher_role
DEC5_RECEIVER_ROLE=your_receiver_role

# ─── Google Maps ─────────────────────────────────────────────────
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your_google_maps_api_key

# ─── Scraping ────────────────────────────────────────────────────
USER_AGENT="Mozilla/5.0 (Windows NT 10.0; Win64; x64) Chrome/120.0.0.0"

# ─── StreamHub ───────────────────────────────────────────────────
STREAMHUB_CLIENT_ID=your_client_id
STREAMHUB_CLIENT_SECRET=your_client_secret
STREAMHUB_AUDIENCE=your_audience
STREAMHUB_URL=https://pgrest.streamhub.cl
STREAMHUB_IOT_URL=https://iot.streamhub.cl

# ─── Fleet Management — temporary pgrest source ──────────────────
# TEMPORARY bypass: when MIOT_FLEET_SOURCE=pgrest, /api/fleet/trucks
# proxies to the prod streamhub pgrest instance instead of the quarkus
# fleet backend. Reuses the existing STREAMHUB_* M2M credentials above
# (token rotation via AuthToken). Remove once quarkus exposes equivalent
# telemetry.
MIOT_FLEET_SOURCE=quarkus

# ─── External Tasks (n8n webhooks) ─────────────────────────────────
EXT_TASKS_WEBHOOK_URL=https://router.streamhub.cl/webhook/{workflow-id}

# ─── Mapbox ──────────────────────────────────────────────────────
NEXT_PUBLIC_DISPLAY_GEOGRAPHIC_VIEW=TRUE
MAPBOX_API_KEY=your_mapbox_api_key

# ─── Feature flags ──────────────────────────────────────────────
NEXT_PUBLIC_SKIP_DRIVER_VERIFICATION=true

# ─── OpenAPI ─────────────────────────────────────────────────────
OPENAPI_URL=https://your-openapi-host.com
OPENAPI_TOKEN=your_api_token_here

# ─── Calendar ────────────────────────────────────────────────────
MIOT_CALENDAR_URL=https://your-calendar-host.com
MIOT_RESOURCE_URL=https://your-resource-host.com
MIOT_DEFAULT_ORG_ID=your_organization_id

# ─── Dashlet ingestion ───────────────────────────────────────────
# Audit metadata stamped on every imported row by the batch_import dashlet.
# DASHLET_INGESTION_SCHEMA_VERSION can be overridden per-dashlet from the
# widget settings UI.
# DASHLET_INGESTION_TIMEZONE=America/Santiago
# DASHLET_INGESTION_CLIENT_ID=
# DASHLET_INGESTION_SCHEMA_VERSION=
