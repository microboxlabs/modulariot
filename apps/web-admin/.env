DATABASE_URL=postgresql://sample_user:sample_pass@host:5432/db_name
AUTH0_DOMAIN=sample_host.region.auth0.com
AUTH0_CLIENT_ID=your_auth0_client_id
AUTH0_CLIENT_SECRET=your_auth0_client_secret
AUTH0_JWT_ALG=RS256 # 'HS256' | 'RS256'
AUTH0_JWT_LIFETIME_IN_SECONDS=86400
INGEST_SERVER_URL="http://localhost:3030"
