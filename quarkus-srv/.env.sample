# =============================================================================
# ModularIoT — Environment Variables
# =============================================================================
# Copy to .env and fill in your values:  cp .env.sample .env
# Quarkus loads .env automatically via MicroProfile Config.

# --- Primary database ---
MIOT_DB_USER=miot
MIOT_DB_PASSWORD=miot
MIOT_DB_REACTIVE_URL=postgresql://localhost:5432/miot_dev
MIOT_DB_JDBC_URL=jdbc:postgresql://localhost:5432/miot_dev

# --- Metrics database (read-only GPS/OBD2) ---
METRICS_DB_USER=streamhub
METRICS_DB_PASSWORD=streamhub
METRICS_DB_URL=postgresql://localhost:8432/prod_iot_gps

# --- Auth0 (used with %auth0 profile) ---
# Copy secret.jwk from quarkus-http-pulsar-publisher to miot-cli/src/main/resources/
AUTH0_ISSUER=https://dev-6pk507y7elk6w3c7.us.auth0.com/
AUTH0_JWT_KEY_LOCATION=secret.jwk

# --- Alfresco ---
ALFRESCO_URL=http://localhost:8080/alfresco
ALFRESCO_USER=admin
ALFRESCO_PASSWORD=admin

# --- External messaging ---
# log = standalone (no broker needed), pulsar = Apache Pulsar
MIOT_MESSAGING_TYPE=log
PULSAR_URL=pulsar://localhost:6650
MIOT_TRACKING_TOPIC=persistent://streamhub/tracking/asset-positions
