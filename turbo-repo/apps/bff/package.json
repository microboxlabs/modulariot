{
  "name": "@modulariot/bff",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsup src/server.ts --format esm --outDir dist",
    "start": "node dist/server.js",
    "test": "NODE_OPTIONS='--import tsx' vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint .",
    "check-types": "tsc --noEmit"
  },
  "dependencies": {
    "@fastify/auth": "^5.0.2",
    "@fastify/autoload": "^6.3.1",
    "@fastify/basic-auth": "^6.2.0",
    "@fastify/cors": "^11.0.1",
    "@fastify/env": "^5.0.2",
    "@fastify/jwt": "^9.1.0",
    "@fastify/swagger": "^9.5.1",
    "@fastify/swagger-ui": "^5.2.3",
    "auth0": "^4.26.0",
    "awilix": "^12.0.5",
    "env-schema": "^6.0.0",
    "fastify": "^5.4.0",
    "fastify-plugin": "^5.0.1"
  },
  "devDependencies": {
    "@repo/eslint-config": "*",
    "@repo/typescript-config": "*",
    "@types/node": "^22.15.3",
    "is-ci": "^4.1.0",
    "tsup": "^8.0.0",
    "tsx": "^4.19.0",
    "typescript": "5.8.2",
    "vitest": "^4.1.9"
  }
}
