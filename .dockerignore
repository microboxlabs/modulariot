# Dependencies - will be installed fresh in Docker
node_modules
**/node_modules
.pnpm-store
**/.pnpm-store

# Build outputs - will be built fresh in Docker
**/.next
**/dist
**/.turbo
**/build
**/out

# Version control
.git
.gitignore

# IDE and editor
.vscode
.idea
*.swp
*.swo
.cursor

# Environment and secrets
.env
.env.*
!.env.example
.npmrc
.npmrc.*
*.key
*.pem
*.p12
*.pfx
*secret*
*password*
*credentials*
.secrets

# Documentation and non-essential
*.md
!README.md
LICENSE
CHANGELOG.md
CODE_OF_CONDUCT.md
CONTRIBUTING.md

# Test files
**/*.test.ts
**/*.test.tsx
**/*.spec.ts
**/*.spec.tsx
**/coverage
**/__tests__
**/__mocks__
**/test
**/tests
*.test.js
*.spec.js

# Development files
.husky
.eslintcache
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
pnpm-lock.yaml
pnpm-workspace.yaml

# CI/CD files (not needed in Docker)
.github
.gitlab-ci.yml
.circleci

# OS files
.DS_Store
Thumbs.db
