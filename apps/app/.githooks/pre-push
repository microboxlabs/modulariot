#!/bin/bash

# Protected branches
protected_branch='develop'
protected_branch_pattern='based/develop'

# Read ref information from stdin
while read local_ref local_sha remote_ref remote_sha
do
    # Extract branch name from ref (e.g., refs/heads/develop -> develop)
    branch_name=${local_ref#refs/heads/}
    
    # Check if pushing to a protected branch
    if [ "$branch_name" = "$protected_branch" ] || [ "$branch_name" = "$protected_branch_pattern" ]; then
        echo ""
        echo "❌ No se aceptan ramas based/develop, si quieres desplegar en desarrollo usa la rama trash, no hagar pr hacia el trash"
        echo ""
        exit 1
    fi
done

exit 0

